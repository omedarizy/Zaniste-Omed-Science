from manim import *

class HydrogenScience(Scene):
    def construct(self):
        # Background: Dark Space with Stars
        stars = Stars(n=200)
        self.add(stars)

        # 1. The Atomic Card (Like your photo 614)
        card = RoundedRectangle(corner_radius=0.2, height=5, width=3.5, color=GOLD)
        card.set_fill(color=BLACK, opacity=0.8)
        
        # Text Styling (Scientific & Clean)
        atomic_num = Text("1", font_size=48, color=GOLD).shift(UP*1.8)
        symbol = Text("H", font_size=140, color=WHITE, weight=BOLD)
        name = Text("هایدرۆجین", font_size=36, color=GOLD).next_to(symbol, DOWN)
        weight = Text("1.008", font_size=24, color=WHITE).next_to(name, DOWN)

        # 2. Creating the Electron Animation
        nucleus = Dot(color=RED, radius=0.15).glow()
        orbit = Ellipse(width=2, height=1, color=BLUE_A).set_stroke(width=1, opacity=0.4)
        electron = Dot(color=BLUE, radius=0.1)
        
        atom_group = VGroup(nucleus, orbit, electron).scale(0.7).next_to(weight, DOWN, buff=0.4)

        # Animation Sequence
        self.play(Create(card), run_time=1.5)
        self.play(Write(atomic_num), Write(symbol))
        self.play(FadeIn(name, shift=UP), Write(weight))
        self.play(Create(nucleus), Create(orbit))
        self.play(FadeIn(electron))

        # 3. Constant Orbiting
        self.play(MoveAlongPath(electron, orbit), run_time=3, rate_func=linear)
        self.wait(2)
